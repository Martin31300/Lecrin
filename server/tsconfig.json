{
  "compilerOptions": {
    "target": "es2023",                     // ✅ version plus récente
    "lib": ["es2023"],                      // ✅ on ajoute la librairie standard ES2023
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["node_modules", "dist"]
}
